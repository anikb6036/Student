# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# RESEND_API_KEY: Required for sending real emails via Resend
RESEND_API_KEY= re_2BS6V4Df_EXtRRVuHKvzZnh6TPaHak4WP

# SENDER_EMAIL: If you verified a domain in Resend, put your verified sender email here (e.g. admissions@yourdomain.com)
# Defaults to onboarding@resend.dev (which has testing restrictions)
SENDER_EMAIL="onboarding@resend.dev"

# SENDER_NAME: Custom display name for the sender
SENDER_NAME="Learnora Admissions"
